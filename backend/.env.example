# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dinesmart

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_URL=http://localhost:3000

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://localhost:3001

# Restaurant Service
RESTAURANT_SERVICE_PORT=3002
RESTAURANT_SERVICE_URL=http://localhost:3002

# Order Service
ORDER_SERVICE_PORT=3003
ORDER_SERVICE_URL=http://localhost:3003

# Inventory Service
INVENTORY_SERVICE_PORT=3004
INVENTORY_SERVICE_URL=http://localhost:3004

# Hygiene Service
HYGIENE_SERVICE_PORT=3005
HYGIENE_SERVICE_URL=http://localhost:3005

# Notification Service
NOTIFICATION_SERVICE_PORT=3006
NOTIFICATION_SERVICE_URL=http://localhost:3006

# Twilio (for SMS OTP - optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Environment
NODE_ENV=development


